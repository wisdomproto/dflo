VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_AI_SERVER_URL=https://your-ai-server.railway.app

# Google Analytics 4 (GA4) — 측정ID. 정적 빌드(build:i18n)와 React 가 같은 값을 공유.
# (build:i18n 의 gaSnippet 이 GA_MEASUREMENT_ID || VITE_GA_MEASUREMENT_ID 로 읽음)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Meta Pixel — 광고 전환/리타게팅. 콤마로 여러 픽셀 ID 가능 (예: "111,222" → 전부 init).
# 정적 빌드(seo.mjs pixelSnippet)와 React(analytics.ts)가 공유. 공개값이라 레포 보관 OK.
# 시장별 분리: 한국어(ko) 페이지는 _KO 픽셀만, 그 외 언어는 아래 기본 픽셀만 발사.
# _KO 미설정 시 ko 도 기본 픽셀로 폴백(graceful).
VITE_META_PIXEL_ID=000000000000000,111111111111111
VITE_META_PIXEL_ID_KO=222222222222222
