{
  "name": "v4",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "predev": "node scripts/sync-reel-vendor.mjs",
    "dev": "vite",
    "sync:reel-vendor": "node scripts/sync-reel-vendor.mjs",
    "prebuild": "node scripts/sync-reel-vendor.mjs",
    "build": "tsc -b && npm run build:i18n && vite build",
    "build:i18n": "node scripts/build-i18n.mjs",
    "extract:marketing": "node scripts/extract-marketing-data.mjs",
    "test": "node --import tsx --test scripts/test/*.mjs",
    "test:i18n": "node --test scripts/test/*.mjs",
    "start": "vite preview --port ${PORT:-3000} --host 0.0.0.0",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@remotion/gif": "4.0.447",
    "@remotion/player": "4.0.447",
    "@supabase/supabase-js": "^2.97.0",
    "@tiptap/extension-image": "^2.27.2",
    "@tiptap/extension-placeholder": "^2.27.2",
    "@tiptap/react": "^2.27.2",
    "@tiptap/starter-kit": "^2.27.2",
    "chart.js": "^4.5.1",
    "chartjs-plugin-zoom": "^2.2.0",
    "react": "^19.2.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.0",
    "remotion": "4.0.447",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.2.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "js-yaml": "^4.1.1",
    "marked": "^18.0.3",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.0",
    "tsx": "^4.22.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^6.4.1"
  }
