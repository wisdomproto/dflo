# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase (for JWT verification)
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Server
PORT=3001
CORS_ORIGIN=http://localhost:5173

# 네이버 검색광고 API (마케팅 키워드 분석) — ContentFlow .env 에서 복사
NAVER_API_LICENSE_KEY=your_naver_license_key
NAVER_API_SECRET_KEY=your_naver_secret_key
NAVER_API_CUSTOMER_ID=your_naver_customer_id

# DataForSEO (구글 키워드 검색량) — ContentFlow .env 에서 복사
DATAFORSEO_LOGIN=your_dataforseo_login
DATAFORSEO_PASSWORD=your_dataforseo_password

# GA4 Data API (사이트 분석 프록시 /api/analytics/*) — npm run setup-ga4-oauth 로 refresh token 발급
GA4_PROPERTY_ID=your_ga4_property_id
GA4_OAUTH_CLIENT_ID=your_oauth_client_id
GA4_OAUTH_CLIENT_SECRET=your_oauth_client_secret
GA4_OAUTH_REFRESH_TOKEN=your_oauth_refresh_token
